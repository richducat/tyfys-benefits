{
  "version": 2,
  "functions": {
    "api/intake-portal-gate.js": {
      "maxDuration": 10,
      "includeFiles": "intake-portal-content.html"
    },
    "api/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "app.tyfys.net"
        }
      ],
      "destination": "/app-shell.html"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "www.app.tyfys.net"
        }
      ],
      "destination": "/app-shell.html"
    },
    {
      "source": "/lupusstudy",
      "destination": "/lupusstudy.html"
    },
    {
      "source": "/clinic",
      "destination": "/clinic.html"
    },
    {
      "source": "/intake-portal",
      "destination": "/api/intake-portal-gate"
    },
    {
      "source": "/intake-portal.html",
      "destination": "/api/intake-portal-gate"
    },
    {
      "source": "/oauth/callback",
      "destination": "/api/zoho-oauth-callback"
    },
    {
      "source": "/zoho/callback",
      "destination": "/api/zoho-oauth-callback"
    }
  ]
}
