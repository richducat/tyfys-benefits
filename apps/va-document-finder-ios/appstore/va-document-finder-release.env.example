# Copy to a private local env file before uploading.
# Do not commit real app-specific passwords, API private keys, or provisioning profile names.

IOS_TEAM_ID=WN3K69XEP4
# Version and build default to project.yml (the source of truth). Only set
# these to deliberately override — a stale pinned value here silently
# archives the wrong version.
# IOS_MARKETING_VERSION=
# IOS_BUILD_NUMBER=
IOS_SIGNING_STYLE=automatic
IOS_PROVISIONING_PROFILE_SPECIFIER=
IOS_EXPORT_METHOD=app-store-connect
APPLE_ID=richard@thedigitalsync.com

# Set only after App Store Connect shows the seller as DIGITAL SYNC, LLC, THE.
DIGITAL_SYNC_CONFIRMED_APPLE_SELLER=false

# Optional upload auth for xcrun altool. Otherwise xcodebuild export destination=upload is used.
# APPLE_ID=
# APP_SPECIFIC_PASSWORD=
# ASC_API_KEY=
# ASC_API_ISSUER=
# ASC_API_P8_PATH=
